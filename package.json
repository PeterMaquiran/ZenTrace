{
  "name": "zentrace",
  "description": "ZenTrace — see what your code actually does.",
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterMaquiran/ZenTrace.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./playwright": {
      "types": "./dist/playwright/index.d.ts",
      "import": "./dist/playwright/index.js"
    }
  },
  "packageManager": "pnpm@11.0.9",
  "volta": {
    "node": "22.22.0",
    "pnpm": "11.0.9"
  },
  "scripts": {
    "prepublishOnly": "pnpm run build:package",
    "lint:fix": "eslint --fix",
    "format": "prettier . --write",
    "dev:ui": "vite ui",
    "dev:demo": "vite ui/demo",
    "build:package": "tsc -p tsconfig.build.json && vite build",
    "build:extension": "vite build",
    "test:extension": "playwright test",
    "test:package": "vitest run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/prompt-cli": "^21.0.2",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^25.9.2",
    "concurrently": "^9.2.1",
    "cross-env-shell": "^7.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "sass-embedded": "^1.100.0",
    "start-server-and-test": "^3.0.5",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "keywords": [
    [
      "trace",
      "tracing",
      "debug",
      "debugging",
      "observability",
      "devtools",
      "profiling",
      "performance",
      "async",
      "async-debugging",
      "call-stack",
      "execution-flow",
      "function-tracing",
      "instrumentation",
      "telemetry",
      "span",
      "distributed-tracing",
      "developer-tools",
      "javascript",
      "typescript"
    ]
  ],
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "preact": "^10.29.2"
  }
}
