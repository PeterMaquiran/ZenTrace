{
  "name": "DevTrace",
  "description": "See what your code actually does.",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "packageManager": "pnpm@11.0.9",
  "volta": {
    "node": "22.22.0",
    "pnpm": "11.0.9"
  },
  "scripts": {
    "lint:fix": "eslint --fix",
    "format": "prettier . --write",
    "dev": "concurrently \"vite playground\" \"cypress open\"",
    "build": "tsc -p tsconfig.build.json && vite build",
    "test:e2e": "node scripts/e2e.js",
    "test:unit": "vitest run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/prompt-cli": "^21.0.2",
    "@eslint/js": "^9.39.4",
    "concurrently": "^9.2.1",
    "cross-env-shell": "^7.0.3",
    "cypress": "^14.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "start-server-and-test": "^3.0.5",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.60.0",
    "uuid": "^14.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "keywords": [
    [
      "trace",
      "tracing",
      "debug",
      "debugging",
      "observability",
      "devtools",
      "profiling",
      "performance",
      "async",
      "async-debugging",
      "call-stack",
      "execution-flow",
      "function-tracing",
      "instrumentation",
      "telemetry",
      "span",
      "distributed-tracing",
      "developer-tools",
      "javascript",
      "typescript"
    ]
  ],
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
